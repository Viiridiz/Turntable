<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Turntable.Models"
             x:Class="Turntable.Views.Seller.MyInventoryPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout WidthRequest="1050" HorizontalOptions="Center" Padding="40" Spacing="25">

            <Label Text="Inventory" TextColor="White" FontSize="32" FontAttributes="Bold" Margin="0,5,0,0" />

            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Post Listing" BackgroundColor="#d4af35" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" HeightRequest="45" WidthRequest="150" Clicked="OnPostListingClicked"/>
                <Border Grid.Column="1" Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" HeightRequest="45" HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Entry x:Name="SearchEntry" Placeholder="Search inventory..." PlaceholderColor="#64748b" TextColor="White" FontSize="14" Margin="15,0" TextChanged="OnSearchTextChanged"/>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="15">
                <Border Grid.Column="0" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Picker x:Name="ConditionFilterPicker" Title="Condition: All" TitleColor="#cbd5e1" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>All Conditions</x:String>
                                <x:String>Mint</x:String>
                                <x:String>Used</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <Border Grid.Column="1" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Picker x:Name="GenreFilterPicker" Title="Genre: All" TitleColor="#cbd5e1" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>All Genres</x:String>
                                <x:String>Rock</x:String>
                                <x:String>Pop</x:String>
                                <x:String>Jazz</x:String>
                                <x:String>Hip Hop</x:String>
                                <x:String>Electronic</x:String>
                                <x:String>RnB</x:String>
                                <x:String>Classic</x:String>
                                <x:String>Country</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <Border Grid.Column="2" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Picker x:Name="SortPicker" Title="Sort: Default" TitleColor="#cbd5e1" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Price: Low to High</x:String>
                                <x:String>Price: High to Low</x:String>
                                <x:String>Year: Newest</x:String>
                                <x:String>Year: Oldest</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>
            </Grid>

            <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" HorizontalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*" HeightRequest="45">
                    <VerticalStackLayout x:Name="ActiveTab" Grid.Column="0" BackgroundColor="#433d28">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnActiveTabTapped"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Label x:Name="ActiveLabel" Text="Active" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,12,0,0"/>
                        <BoxView x:Name="ActiveIndicator" BackgroundColor="#d4af35" HeightRequest="2" VerticalOptions="EndAndExpand"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="SoldTab" Grid.Column="1" BackgroundColor="Transparent">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSoldTabTapped"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Label x:Name="SoldLabel" Text="Sold" TextColor="#cbd5e1" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,12,0,0"/>
                        <BoxView x:Name="SoldIndicator" BackgroundColor="Transparent" HeightRequest="2" VerticalOptions="EndAndExpand"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <CollectionView x:Name="ListingList" ItemSizingStrategy="MeasureAllItems">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="15" VerticalItemSpacing="15"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ListingModel">
                        <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">

                                <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="200" HeightRequest="200" HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="0"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                </Border>

                                <Label Text="{Binding AlbumName}" TextColor="White" FontAttributes="Bold" FontSize="16" CharacterSpacing="1"/>
                                <Label Text="{Binding Artist}" TextColor="#94a3b8" FontSize="12"/>

                                <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                                    <Label Grid.Column="0" Text="{Binding Condition}" TextColor="#d4af35" FontSize="11" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding Price, StringFormat='${0:F2}'}" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                                    <Button Text="EDIT" FontSize="10" BackgroundColor="#334155" TextColor="White" HeightRequest="30" Clicked="OnEditClicked"/>
                                    <Button Grid.Column="1" Text="DELETE" FontSize="10" BackgroundColor="#8b0000" TextColor="White" HeightRequest="30" Clicked="OnDeleteClicked"/>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>