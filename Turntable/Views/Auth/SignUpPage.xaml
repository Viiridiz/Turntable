<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.Views.Auth.SignUpPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView MaximumWidthRequest="400" HorizontalOptions="Center" VerticalOptions="Center">
        <VerticalStackLayout Padding="20" Spacing="30">

            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Grid WidthRequest="80" HeightRequest="80">
                    <Ellipse Stroke="#d4af35" StrokeThickness="2" />
                    <Ellipse Stroke="#d4af35" StrokeThickness="2" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Ellipse Fill="#d4af35" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <Label Text="Turntable"
           TextColor="White"
           FontSize="38"
           FontAttributes="Bold"
           VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" HeightRequest="50">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*">
                    <Button x:Name="BuyerBtn" Text="Collector" BackgroundColor="#d4af35" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" Clicked="OnBuyerClicked"/>
                    <Button x:Name="SellerBtn" Grid.Column="1" Text="Seller" BackgroundColor="Transparent" TextColor="#94a3b8" FontAttributes="Bold" CornerRadius="0" Clicked="OnSellerClicked"/>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Full Name" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" />
                    <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" HeightRequest="56">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Entry x:Name="FullNameEntry"
                               Placeholder="Enter your full name"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Email Address" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" />
                    <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" HeightRequest="56">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Entry x:Name="EmailEntry"
                               Placeholder="name@example.com"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               Keyboard="Email"
                               Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Password" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" />
                    <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent" HeightRequest="56">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Entry x:Name="PasswordEntry"
                               IsPassword="True"
                               Placeholder="••••••••"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="Sign Up"
                        BackgroundColor="White"
                        TextColor="#1a1812"
                        FontAttributes="Bold"
                        CornerRadius="0"
                        HeightRequest="56"
                        Clicked="OnSignUpClicked"
                        Margin="0,10,0,0"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,20,0,0">
                    <Label Text="Already have an account?" TextColor="#94a3b8" FontSize="12" />
                    <Label Text="Log in" TextColor="White" FontSize="12" FontAttributes="Bold" TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoToSignInPage" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Label x:Name="result" TextColor="Red" HorizontalOptions="Center" FontSize="12" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>