<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.Views.Auth.ForgotPasswordPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView MaximumWidthRequest="440" HorizontalOptions="Center" VerticalOptions="Center">
        <VerticalStackLayout Padding="20" Spacing="30">

            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                    <Grid WidthRequest="80" HeightRequest="80">
                        <Ellipse Stroke="#d4af35" StrokeThickness="2" />
                        <Ellipse Stroke="#d4af35" StrokeThickness="2" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Ellipse Fill="#d4af35" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>

                    <Label Text="Turntable"
               TextColor="White"
               FontSize="38"
               FontAttributes="Bold"
               VerticalOptions="Center"/>
                </HorizontalStackLayout>

            <Border BackgroundColor="Transparent"
                    Stroke="#d4af35"
                    StrokeThickness="1"
                    Padding="30">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">
                    <Label Text="Forgot Password" TextColor="White" FontSize="20" FontAttributes="Bold" />

                    <Label Text="Enter your email to reset your password. We'll send you a link to get back into your account." 
                           TextColor="#94a3b8" 
                           FontSize="14" />

                    <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                        <Label Text="Email Address" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" />
                        <Border Stroke="#d4af35" StrokeThickness="1" BackgroundColor="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <Entry x:Name="EmailEntry"
                                   Placeholder="your@email.com"
                                   PlaceholderColor="#64748b"
                                   TextColor="White"
                                   BackgroundColor="Transparent"
                                   Keyboard="Email"
                                   ClearButtonVisibility="WhileEditing" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Reset Password"
                            BackgroundColor="#d4af35"
                            TextColor="#1a1812"
                            FontAttributes="Bold"
                            CornerRadius="0"
                            HeightRequest="50"
                            Clicked="OnResetPasswordClicked"
                            Margin="0,10,0,0"/>

                    <Label x:Name="ResultMessage" TextColor="Red" HorizontalOptions="Center" FontSize="12" HorizontalTextAlignment="Center" />

                    <BoxView HeightRequest="1" Color="#2a271e" Margin="0,10" />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                        <Label Text="←" TextColor="White" FontSize="16" />
                        <Label Text="Back to Login" TextColor="White" FontSize="14" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackToLoginClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>