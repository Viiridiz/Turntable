<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Turntable.Models"
             x:Class="Turntable.Views.Buyer.MyOrdersPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#1a1812" Stroke="#334155" StrokeThickness="1" StrokeShape="Rectangle">
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,15" VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Grid WidthRequest="30" HeightRequest="30">
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" />
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Ellipse Fill="#d4af35" WidthRequest="4" HeightRequest="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="Turntable" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="30" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Marketplace" TextColor="#94a3b8" FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMarketplaceTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="My Orders" TextColor="#d4af35" FontSize="14" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="20" VerticalOptions="Center">
                    <Label Text="Cart" TextColor="White" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCartTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Profile" TextColor="White" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout WidthRequest="1050" HorizontalOptions="Center" Padding="40,60,40,40" Spacing="30">

                <VerticalStackLayout Spacing="5">
                    <Label Text="MY ORDERS" TextColor="White" FontSize="32" FontAttributes="Bold" />
                    <Label Text="PURCHASE HISTORY &amp; SHIPMENT TRACKING" TextColor="#64748b" FontSize="12" FontAttributes="Bold" CharacterSpacing="1"/>
                </VerticalStackLayout>

                <HorizontalStackLayout Spacing="15" Margin="0,10,0,0">
                    <Button x:Name="AllBtn" Text="ALL ORDERS" BackgroundColor="#d4af35" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" HeightRequest="40" Padding="20,0" Clicked="OnFilterClicked"/>
                    <Button x:Name="ProcessingBtn" Text="PROCESSING" BackgroundColor="Transparent" BorderColor="#334155" BorderWidth="1" TextColor="#94a3b8" FontAttributes="Bold" CornerRadius="0" HeightRequest="40" Padding="20,0" Clicked="OnFilterClicked"/>
                    <Button x:Name="ShippedBtn" Text="SHIPPED" BackgroundColor="Transparent" BorderColor="#334155" BorderWidth="1" TextColor="#94a3b8" FontAttributes="Bold" CornerRadius="0" HeightRequest="40" Padding="20,0" Clicked="OnFilterClicked"/>
                    <Button x:Name="DeliveredBtn" Text="DELIVERED" BackgroundColor="Transparent" BorderColor="#334155" BorderWidth="1" TextColor="#94a3b8" FontAttributes="Bold" CornerRadius="0" HeightRequest="40" Padding="20,0" Clicked="OnFilterClicked"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="2" Color="#334155" Margin="0,10"/>

                <Grid ColumnDefinitions="150, 150, *, 150, 150" Margin="10,0">
                    <Label Grid.Column="0" Text="ORDER #" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <Label Grid.Column="1" Text="DATE" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <Label Grid.Column="2" Text="ALBUM / ARTIST" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <Label Grid.Column="3" Text="PRICE" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                    <Label Grid.Column="4" Text="STATUS" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" HorizontalOptions="End"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#334155"/>

                <CollectionView x:Name="OrdersList" ItemSizingStrategy="MeasureAllItems">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderModel">
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="150, 150, *, 150, 150" Padding="10,25" VerticalOptions="Center">
                                    <Label Grid.Column="0" Text="{Binding OrderId}" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding OrderDate, StringFormat='{0:MMM dd, yyyy}'}" TextColor="#94a3b8" FontSize="14" VerticalOptions="Center"/>

                                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding AlbumName}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                        <Label Text="{Binding Artist}" TextColor="#64748b" FontSize="12"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="3" Text="{Binding PurchasePrice, StringFormat='${0:F2}'}" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>

                                    <Border Grid.Column="4" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,8" HorizontalOptions="End" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="0"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Status}" TextColor="#d4af35" FontSize="10" FontAttributes="Bold" CharacterSpacing="1"/>
                                    </Border>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#26241c"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="No orders found." TextColor="#64748b" FontSize="14" Margin="10,20"/>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>