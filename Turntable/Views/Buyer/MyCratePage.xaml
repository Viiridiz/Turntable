<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Turntable.Models"
             x:Class="Turntable.Views.Buyer.MyCratePage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#1a1812" Stroke="#334155" StrokeThickness="1" StrokeShape="Rectangle">
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,15" VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Grid WidthRequest="30" HeightRequest="30">
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" />
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Ellipse Fill="#d4af35" WidthRequest="4" HeightRequest="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="Turntable" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="30" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Marketplace" TextColor="#94a3b8" FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToExploreTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Orders" TextColor="#94a3b8" FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="20" VerticalOptions="Center">
                    <Label Text="Cart" TextColor="#d4af35" FontSize="14" VerticalOptions="Center" FontAttributes="Bold"/>
                    <Label Text="Profile" TextColor="White" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout WidthRequest="1050" HorizontalOptions="Center" Padding="40" Spacing="40">

                <Label Text="YOUR CRATE" TextColor="White" FontSize="32" FontAttributes="Bold" />

                <Grid ColumnDefinitions="*, 350" ColumnSpacing="60">

                    <VerticalStackLayout Grid.Column="0" Spacing="40">

                        <CollectionView x:Name="CartCollectionView" ItemSizingStrategy="MeasureAllItems">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ListingModel">
                                    <VerticalStackLayout Spacing="20">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                                            <Border Grid.Column="0" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="100" HeightRequest="100">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="0"/>
                                                </Border.StrokeShape>
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                                <Label Text="{Binding AlbumName}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                                <Label Text="{Binding Artist}" TextColor="#94a3b8" FontSize="14"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="15">
                                                <Label Text="{Binding Price, StringFormat='${0:F2}'}" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="End"/>
                                                <Label Text="REMOVE" TextColor="#64748b" FontSize="11" FontAttributes="Bold" TextDecorations="Underline" HorizontalOptions="End">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnRemoveTapped" CommandParameter="{Binding .}"/>
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </VerticalStackLayout>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#334155" Margin="0,0,0,0"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Your crate is empty." TextColor="#64748b" FontSize="16" Margin="0,20"/>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <VerticalStackLayout Spacing="15" Margin="0,20,0,0">
                            <Label Text="DELIVERY METHOD" TextColor="White" FontSize="14" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Border StrokeThickness="0" BackgroundColor="#26241c" HeightRequest="55">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,*">
                                    <Button x:Name="ShippingBtn" Text="SHIPPING" BackgroundColor="#d4af35" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" Clicked="OnShippingClicked"/>
                                    <Button x:Name="MeetupBtn" Grid.Column="1" Text="LOCAL MEETUP" BackgroundColor="Transparent" TextColor="#94a3b8" FontAttributes="Bold" CornerRadius="0" Clicked="OnMeetupClicked"/>
                                </Grid>
                            </Border>
                            <Border StrokeThickness="0" BackgroundColor="#26241c" HeightRequest="55" Margin="0,10,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0"/>
                                </Border.StrokeShape>
                                <Entry x:Name="AddressEntry" Placeholder="Delivery Address..." PlaceholderColor="#64748b" TextColor="White" Margin="15,0"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Border Grid.Column="1" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="30" VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="20">
                            <Label Text="SUMMARY" TextColor="White" FontSize="16" FontAttributes="Bold" CharacterSpacing="1"/>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <Label Grid.Column="0" Text="SUBTOTAL" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold"/>
                                <Label Grid.Column="1" x:Name="SubtotalLabel" Text="$0.00" TextColor="White" FontSize="14"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="ESTIMATED TAX" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold"/>
                                <Label Grid.Column="1" x:Name="TaxLabel" Text="$0.00" TextColor="White" FontSize="14"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="SHIPPING" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold"/>
                                <Label Grid.Column="1" x:Name="ShippingLabel" Text="$0.00" TextColor="White" FontSize="14"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#334155" Margin="0,10"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="TOTAL" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                <Label Grid.Column="1" x:Name="TotalLabel" Text="$0.00" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                            </Grid>

                            <VerticalStackLayout Spacing="15" Margin="0,20,0,0">
                                <Button Text="PROCEED TO PAYMENT" BackgroundColor="#d4af35" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" HeightRequest="50" Clicked="OnProceedToPaymentClicked"/>
                                <Button Text="BACK TO EXPLORE" BackgroundColor="Transparent" BorderColor="#334155" BorderWidth="1" TextColor="White" FontAttributes="Bold" CornerRadius="0" HeightRequest="50" Clicked="OnBackToExploreTapped"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>