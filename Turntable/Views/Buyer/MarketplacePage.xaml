<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Turntable.Models"
             x:Class="Turntable.Views.Buyer.MarketplacePage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#1a1812" Stroke="#334155" StrokeThickness="1" StrokeShape="Rectangle">
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,15" VerticalOptions="Center">

                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Grid WidthRequest="30" HeightRequest="30">
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" />
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Ellipse Fill="#d4af35" WidthRequest="4" HeightRequest="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="Turntable" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="30" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Marketplace" TextColor="#d4af35" FontSize="14" FontAttributes="Bold"/>
                    <Label Text="My Orders" TextColor="#94a3b8" FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMyOrdersTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="20" VerticalOptions="Center">
                    <Label Text="Cart" TextColor="White" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCartTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Profile" TextColor="White" FontSize="14" VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout WidthRequest="1050" HorizontalOptions="Center" Padding="40,20,40,40" Spacing="30">

                <Border StrokeThickness="0" HeightRequest="55" HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Entry x:Name="SearchEntry" Placeholder="Search albums or artists by name..." PlaceholderColor="#64748b" TextColor="White" FontSize="14" Margin="15,0" TextChanged="OnSearchTextChanged"/>
                </Border>

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="15">

                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Condition" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold" />
                        <Border StrokeThickness="0" HorizontalOptions="Fill" HeightRequest="55">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <Picker x:Name="ConditionPicker" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>All Conditions</x:String>
                                        <x:String>Mint</x:String>
                                        <x:String>Used</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Genre" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold" />
                        <Border StrokeThickness="0" HorizontalOptions="Fill" HeightRequest="55">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <Picker x:Name="GenrePicker" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>All Genres</x:String>
                                        <x:String>Rock</x:String>
                                        <x:String>Pop</x:String>
                                        <x:String>Jazz</x:String>
                                        <x:String>Hip Hop</x:String>
                                        <x:String>Electronic</x:String>
                                        <x:String>RnB</x:String>
                                        <x:String>Classic</x:String>
                                        <x:String>Country</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="5">
                        <Label Text="Sort By" TextColor="#cbd5e1" FontSize="12" FontAttributes="Bold" />
                        <Border StrokeThickness="0" HorizontalOptions="Fill" HeightRequest="55">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <Picker x:Name="SortPicker" TextColor="White" Margin="10,0" HorizontalOptions="Fill" VerticalOptions="Center" SelectedIndexChanged="OnFilterChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Price: Low to High</x:String>
                                        <x:String>Price: High to Low</x:String>
                                        <x:String>Year: Newest</x:String>
                                        <x:String>Year: Oldest</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                </Grid>

                <CollectionView x:Name="MarketplaceList" ItemSizingStrategy="MeasureAllItems" SelectionMode="Single" SelectionChanged="OnListingSelected">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="25" VerticalItemSpacing="40"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ListingModel">
                            <VerticalStackLayout Spacing="10">
                                <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="235" HeightRequest="235" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="0"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                </Border>
                                <Label Text="{Binding AlbumName}" TextColor="White" FontAttributes="Bold" FontSize="16" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Artist}" TextColor="#94a3b8" FontSize="14" LineBreakMode="TailTruncation"/>
                                <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                                    <Label Grid.Column="0" Text="{Binding Price, StringFormat='${0:F2}'}" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                                    <Border Grid.Column="1" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="35" HeightRequest="35">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="0"/>
                                        </Border.StrokeShape>
                                        <Label Text="🛒" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>