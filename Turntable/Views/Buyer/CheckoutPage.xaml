<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.Views.Buyer.CheckoutPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#1a1812" Stroke="#334155" StrokeThickness="1" StrokeShape="Rectangle">
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,15" VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Grid WidthRequest="30" HeightRequest="30">
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" />
                        <Ellipse Stroke="#d4af35" StrokeThickness="1.5" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Ellipse Fill="#d4af35" WidthRequest="4" HeightRequest="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="Turntable" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="30" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Marketplace" TextColor="#94a3b8" FontSize="14" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMarketplaceTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Orders" TextColor="#94a3b8" FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="20" VerticalOptions="Center">
                    <Label Text="Cart" TextColor="#d4af35" FontSize="14" VerticalOptions="Center" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCartTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Profile" TextColor="White" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout WidthRequest="700" HorizontalOptions="Center" Padding="40,60,40,60" Spacing="40">

                <VerticalStackLayout Spacing="20">
                    <Label Text="YOUR CRATE" TextColor="White" FontSize="24" FontAttributes="Bold" />
                    <BoxView HeightRequest="1" Color="#334155" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Items Total" TextColor="#cbd5e1" FontSize="16" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" x:Name="ItemsTotalLabel" Text="$0.00" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Simulated Tax &amp; Fees" TextColor="#cbd5e1" FontSize="16" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" x:Name="TaxLabel" Text="$0.00" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#334155" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="TOTAL" TextColor="White" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" x:Name="GrandTotalLabel" Text="$0.00" TextColor="White" FontSize="28" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End"/>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="20" Margin="0,10,0,0">
                    <Label Text="PAYMENT METHOD" TextColor="White" FontSize="18" FontAttributes="Bold" />

                    <VerticalStackLayout Spacing="15">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="CARD NUMBER" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                            <Border StrokeThickness="0" BackgroundColor="#26241c" HeightRequest="55">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0"/>
                                </Border.StrokeShape>
                                <Entry x:Name="CardNumberEntry" Placeholder="0000 0000 0000 0000" PlaceholderColor="#64748b" TextColor="White" Keyboard="Numeric" MaxLength="19" Margin="15,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="EXPIRY" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                                <Border StrokeThickness="0" BackgroundColor="#26241c" HeightRequest="55">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="0"/>
                                    </Border.StrokeShape>
                                    <Entry x:Name="ExpiryEntry" Placeholder="MM/YY" PlaceholderColor="#64748b" TextColor="White" MaxLength="5" Margin="15,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="CVV" TextColor="#cbd5e1" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                                <Border StrokeThickness="0" BackgroundColor="#26241c" HeightRequest="55">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="0"/>
                                    </Border.StrokeShape>
                                    <Entry x:Name="CvvEntry" Placeholder="123" PlaceholderColor="#64748b" TextColor="White" Keyboard="Numeric" MaxLength="4" Margin="15,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <Button x:Name="ConfirmBtn" Text="CONFIRM PURCHASE" BackgroundColor="White" TextColor="#1a1812" FontAttributes="Bold" FontSize="16" CharacterSpacing="2" CornerRadius="0" HeightRequest="60" Margin="0,20,0,10" Clicked="OnConfirmPurchaseClicked"/>

                </VerticalStackLayout>

                <Label Text="Cancel and return to cart" TextColor="#94a3b8" FontSize="14" HorizontalOptions="Center" Margin="0,10,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCancelTapped"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>