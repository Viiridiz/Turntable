<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.Views.Buyer.ListingDetailPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout WidthRequest="1050" HorizontalOptions="Center" Padding="40" Spacing="40">

            <HorizontalStackLayout Spacing="10">
                <Label Text="Marketplace" TextColor="#64748b" FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text=">" TextColor="#334155" FontSize="14"/>
                <Label x:Name="BreadcrumbGenre" TextColor="#64748b" FontSize="14"/>
                <Label Text=">" TextColor="#334155" FontSize="14"/>
                <Label x:Name="BreadcrumbArtist" TextColor="White" FontSize="14"/>
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="450, *" ColumnSpacing="60">
                <Border Grid.Column="0" Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="450" HeightRequest="450" VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0"/>
                    </Border.StrokeShape>
                    <Image x:Name="CoverImage" Aspect="AspectFill"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="25">
                    <VerticalStackLayout Spacing="5">
                        <Label x:Name="TitleLabel" TextColor="White" FontSize="42" FontAttributes="Bold" LineBreakMode="WordWrap"/>
                        <Label x:Name="ArtistLabel" TextColor="#cbd5e1" FontSize="20"/>
                    </VerticalStackLayout>

                    <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" WidthRequest="150" HorizontalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Label x:Name="PriceLabel" TextColor="White" FontSize="24" FontAttributes="Bold" Margin="15,10"/>
                    </Border>

                    <HorizontalStackLayout Spacing="20">
                        <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0"/>
                            </Border.StrokeShape>
                            <Label x:Name="ConditionLabel" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                        </Border>
                        <Label x:Name="YearLabel" TextColor="#94a3b8" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="DurationLabel" TextColor="#94a3b8" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="25" Margin="0,15,0,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                            <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                <Label Text="LOGISTICS" TextColor="#64748b" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                                <Label x:Name="FulfillmentLabel" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="ADD TO CRATE" BackgroundColor="White" TextColor="#1a1812" FontAttributes="Bold" CornerRadius="0" HeightRequest="50" WidthRequest="200" Clicked="OnAddToCrateClicked"/>
                        </Grid>
                    </Border>

                    <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="Transparent" Padding="25">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                            <Label Text="Seller Verified" TextColor="#d4af35" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="Contact Seller" BackgroundColor="Transparent" BorderColor="#334155" BorderWidth="1" TextColor="White" CornerRadius="0" HeightRequest="40" Padding="15,0"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="60" Margin="0,20,0,50">
                <VerticalStackLayout Grid.Column="0" Spacing="15">
                    <Label Text="SIDE A" TextColor="White" FontSize="14" FontAttributes="Bold" CharacterSpacing="2"/>
                    <BoxView HeightRequest="1" Color="#334155"/>
                    <VerticalStackLayout x:Name="SideALayout" Spacing="10"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="15">
                    <Label Text="SIDE B" TextColor="White" FontSize="14" FontAttributes="Bold" CharacterSpacing="2"/>
                    <BoxView HeightRequest="1" Color="#334155"/>
                    <VerticalStackLayout x:Name="SideBLayout" Spacing="10"/>
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>