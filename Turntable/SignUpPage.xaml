<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.SignUpPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView MaximumWidthRequest="500" HorizontalOptions="Center">
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

            <Label Text="Create an Account"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label Text="Join the club and start collecting"
                   FontSize="14"
                   TextColor="#94a3b8"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Border BackgroundColor="#2a271e"
                    Stroke="#d4af35"
                    StrokeThickness="1"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Email Address" TextColor="#cbd5e1" FontSize="12" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="alex@example.com"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="#1a1812"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Password" TextColor="#cbd5e1" FontSize="12" HorizontalOptions="Start" />
                        <Entry x:Name="PasswordEntry"
                               IsPassword="True"
                               Placeholder="••••••••"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="#1a1812" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="I am a:" TextColor="#cbd5e1" FontSize="12" />
                        <Picker x:Name="RolePicker" 
                                Title="Select your role" 
                                TitleColor="#64748b" 
                                TextColor="White" 
                                BackgroundColor="#1a1812">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Collector</x:String>
                                    <x:String>Seller</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </VerticalStackLayout>

                    <Button Text="SIGN UP"
                            BackgroundColor="#d4af35"
                            TextColor="#1a1812"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50"
                            Clicked="OnSignUpClicked"
                            Margin="0,10,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="Already have an account?" TextColor="#94a3b8" FontSize="14" />
                        <Label Text="Sign In" TextColor="#d4af35" FontSize="14" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGoToSignInPage" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <Label x:Name="result" TextColor="Red" HorizontalOptions="Center" FontSize="12" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>