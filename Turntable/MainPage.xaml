<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.MainPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="350">

            <Label Text="TURNTABLE"
                   TextColor="#d4af35"
                   FontSize="40"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,40" />

            <Button Text="Sign In"
                    BackgroundColor="#d4af35"
                    TextColor="#1a1812"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"
                    Clicked="OnSignInClicked"/>

            <Button Text="Get Started"
                    BackgroundColor="#2a271e"
                    TextColor="White"
                    BorderColor="#d4af35"
                    BorderWidth="1"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"
                    Clicked="OnSignUpClicked"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>