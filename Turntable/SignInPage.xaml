<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Turntable.SignInPage"
             BackgroundColor="#1a1812"
             NavigationPage.HasNavigationBar="False">

    <ScrollView MaximumWidthRequest="500" HorizontalOptions="Center">
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

            <Label Text="Welcome Back"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label Text="Access your curated vinyl collection"
                   FontSize="14"
                   TextColor="#94a3b8"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Border BackgroundColor="#2a271e"
                    Stroke="#d4af35"
                    StrokeThickness="1"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Email Address" TextColor="#cbd5e1" FontSize="12" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="alex@example.com"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="#1a1812"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Grid>
                            <Label Text="Password" TextColor="#cbd5e1" FontSize="12" HorizontalOptions="Start" />
                            <Label Text="Forgot Password?" TextColor="#d4af35" FontSize="12" HorizontalOptions="End" />
                        </Grid>
                        <Entry x:Name="PasswordEntry"
                               IsPassword="True"
                               Placeholder="••••••••"
                               PlaceholderColor="#64748b"
                               TextColor="White"
                               BackgroundColor="#1a1812" />
                    </VerticalStackLayout>

                    <Button Text="SIGN IN"
                            BackgroundColor="#d4af35"
                            TextColor="#1a1812"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50"
                            Clicked="OnSignInClicked"
                            Margin="0,10,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="New to the club?" TextColor="#94a3b8" FontSize="14" />
                        <Label Text="Create an Account" TextColor="#d4af35" FontSize="14" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGoToSignUpPage" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <Label x:Name="result" TextColor="Red" HorizontalOptions="Center" FontSize="12" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>